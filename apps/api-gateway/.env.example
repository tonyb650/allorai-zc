# Server Configuration
PORT=3001
NODE_ENV=development

# Service URLs
AGENTS_URL=http://localhost:8000

# CORS Configuration
# Wildcard will not work with cookie
CORS_ORIGIN=http://localhost:4200

# Logging
LOG_LEVEL=info

# Database
# When DISABLE_DB=true the gateway runs without Supabase and SUPABASE_URL/SUPABASE_KEY can be omitted.
# Chat sessions are issued via crypto.randomUUID() and messages are not persisted.
DISABLE_DB=false
SUPABASE_URL=
SUPABASE_KEY=
