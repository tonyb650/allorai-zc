NX_PUBLIC_API_BASE_URL=http://localhost:3001

# Slow the api to show loading states
NX_PUBLIC_SLOW_API=true

# all | on-error | none
NX_PUBLIC_USE_SAMPLE_DATA=none

# Supabase (same values as platform app)
NX_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NX_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>