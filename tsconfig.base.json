{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@allorai/source"],
    "paths": {
      "itineraries/*": ["./apps/web/itineraries/src/*"],
      "@allorai/shared-ui": ["./libs/shared/ui/src/index.ts"],
      "@allorai/shared-types": ["./libs/shared/types/src/index.ts"]
    }
  }
}
